# OpenZL VM Instruction Set Definition
#
# Single source of truth for SDDL2 VM opcodes - used by:
# - C11 VM (via generated sddl2_opcodes.h)
# - Python assembler (via generated opcodes_generated.py)
# - C++ compiler (via generated sddl2_opcodes.h)
#
# Format:
#   @family NAME ID "Description"
#     mnemonic  opcode  [params]  "Description"
#
# Parameter types: u32, i32, i64
#
# To regenerate: python3 tools/sddl/assembler/generate_opcodes.py

# ============================================================================
# OPCODE FAMILIES & INSTRUCTIONS
# ============================================================================

@family PUSH 0x0001 "Push constants and values onto stack"
  zero      0x0001          "Push constant value 0 onto stack"
  u32       0x0002  u32     "Push unsigned 32-bit immediate value onto stack"
  i32       0x0003  i32     "Push signed 32-bit immediate value onto stack"
  i64       0x0004  i64     "Push signed 64-bit immediate value onto stack"

@family MATH 0x0002 "Arithmetic operations on I64 values"
  add       0x0001          "Pop two I64 values, push their sum"
  sub       0x0002          "Pop two I64 values, push their difference (second - first)"
  mul       0x0003          "Pop two I64 values, push their product"
  div       0x0004          "Pop two I64 values, push their quotient (second / first)"
  mod       0x0005          "Pop two I64 values, push their remainder (second % first)"
  abs       0x0006          "Pop I64 value, push its absolute value"
  neg       0x0007          "Pop I64 value, push its negation"

@family CMP 0x0003 "Comparison operations on signed I64 values"
  eq        0x0001          "Pop two I64 values, push 1 if equal, 0 otherwise"
  ne        0x0002          "Pop two I64 values, push 1 if not equal, 0 otherwise"
  lt        0x0003          "Pop two I64 values, push 1 if second < first, 0 otherwise"
  le        0x0004          "Pop two I64 values, push 1 if second <= first, 0 otherwise"
  gt        0x0005          "Pop two I64 values, push 1 if second > first, 0 otherwise"
  ge        0x0006          "Pop two I64 values, push 1 if second >= first, 0 otherwise"

@family LOGIC 0x0004 "Logical operations"

@family CONTROL 0x0005 "Control flow operations"
  halt      0x0001          "Stop VM execution"

@family LOAD 0x0006 "Load operations"

@family STACK 0x0007 "Stack manipulation operations"
  dup       0x0001          "Duplicate top stack value"
  drop      0x0002          "Remove top stack value"
  swap      0x0003          "Swap top two stack values"
  over      0x0004          "Copy second stack value to top"
  rot       0x0005          "Rotate top three stack values"

@family TYPE 0x0008 "Type operations"

@family VAR 0x0009 "Variable operations"

@family EXPECT 0x000A "Expect/validation operations"

@family CALL 0x000B "Function call operations"

@family SEGMENT 0x000C "Segment creation operations"
  create_unspecified  0x0001  "Create an unspecified segment type"
