/*
 * OpenZL VM Instruction Set Definition
 *
 * Single source of truth for opcodes - used by:
 * - C11 VM (direct inclusion with X-macros)
 * - Python assembler (parsed by generate_opcodes.py)
 * - C++ compiler (direct inclusion with X-macros)
 *
 * X-Macro Format:
 *   FAMILY_DEF(name, id)
 *   OPCODE_DEF(mnemonic, family, opcode [, param_type...])
 *
 * Parameter types (variadic):
 *   u32 - unsigned 32-bit
 *   i32 - signed 32-bit
 *   i64 - signed 64-bit
 *
 * Example C11 Usage:
 *
 *   // Generate family enum
 *   #define FAMILY_DEF(name, id) OPENZL_FAMILY_##name = id,
 *   enum openzl_family {
 *       #include "openzl_opcodes.h"
 *   };
 *   #undef FAMILY_DEF
 *
 *   // Generate opcode enum
 *   #define OPCODE_DEF(mnem, fam, op, ...) OPENZL_OP_##fam##_##op,
 *   enum openzl_opcode {
 *       #include "openzl_opcodes.h"
 *   };
 *   #undef OPCODE_DEF
 */

/* ============================================================================
 * FAMILY DEFINITIONS
 * ========================================================================= */

FAMILY_DEF(PUSH,    0x0001)
FAMILY_DEF(MATH,    0x0002)
FAMILY_DEF(CMP,     0x0003)
FAMILY_DEF(LOGIC,   0x0004)
FAMILY_DEF(CONTROL, 0x0005)
FAMILY_DEF(LOAD,    0x0006)
FAMILY_DEF(STACK,   0x0007)
FAMILY_DEF(TYPE,    0x0008)
FAMILY_DEF(VAR,     0x0009)
FAMILY_DEF(EXPECT,  0x000A)
FAMILY_DEF(CALL,    0x000B)


/* ============================================================================
 * OPCODE DEFINITIONS
 * ========================================================================= */

/* CONTROL family (0x0005) - Control flow operations */
OPCODE_DEF(halt, CONTROL, 0x0001)

/* PUSH family (0x0001) - Push constants and values onto stack */
OPCODE_DEF(push.zero, PUSH, 0x0001)
OPCODE_DEF(push.u32,  PUSH, 0x0002, u32)
OPCODE_DEF(push.i32,  PUSH, 0x0003, i32)
OPCODE_DEF(push.i64,  PUSH, 0x0004, i64)

/* STACK family (0x0007) - Stack manipulation operations */
OPCODE_DEF(stack.dup,  STACK, 0x0001)
OPCODE_DEF(stack.drop, STACK, 0x0002)
OPCODE_DEF(stack.swap, STACK, 0x0003)
OPCODE_DEF(stack.over, STACK, 0x0004)
OPCODE_DEF(stack.rot,  STACK, 0x0005)

/* MATH family (0x0002) - Arithmetic operations on I64 values */
OPCODE_DEF(math.add, MATH, 0x0001)
OPCODE_DEF(math.sub, MATH, 0x0002)
OPCODE_DEF(math.mul, MATH, 0x0003)
OPCODE_DEF(math.div, MATH, 0x0004)
OPCODE_DEF(math.mod, MATH, 0x0005)
OPCODE_DEF(math.abs, MATH, 0x0006)
OPCODE_DEF(math.neg, MATH, 0x0007)

/* CMP family (0x0003) - Comparison operations on signed I64 values */
OPCODE_DEF(cmp.eq, CMP, 0x0001)
OPCODE_DEF(cmp.ne, CMP, 0x0002)
OPCODE_DEF(cmp.lt, CMP, 0x0003)
OPCODE_DEF(cmp.le, CMP, 0x0004)
OPCODE_DEF(cmp.gt, CMP, 0x0005)
OPCODE_DEF(cmp.ge, CMP, 0x0006)
